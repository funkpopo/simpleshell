{
  "name": "simpleshell",
  "productName": "SimpleShell",
  "version": "0.4.29",
  "description": "A Simple Electron SSH Terminal for Windows",
  "main": ".webpack/main",
  "scripts": {
    "format": "prettier --write .",
    "prepare:native-sidecar": "node scripts/prepare-rust-sidecar.js",
    "start": "npm run prepare:native-sidecar && set NODE_ENV=development && electron-forge start",
    "package": "npm run prepare:native-sidecar && electron-forge package",
    "make": "npm run prepare:native-sidecar && electron-forge make",
    "publish": "npm run prepare:native-sidecar && electron-forge publish",
    "check:i18n": "node scripts/check-i18n.js",
    "check:a11y": "node scripts/accessibility-scan.js",
    "lint": "eslint src scripts webpack.main.config.js webpack.renderer.config.js webpack.rules.js forge.config.js eslint.config.js",
    "format:check": "prettier --check .",
    "test": "npm run check:i18n && npm run check:a11y && node scripts/regression/error-classification-regression.js && node scripts/regression/ipc-schema-regression.js && node scripts/regression/preload-sandbox-regression.js && node scripts/regression/todo-regression.js && node scripts/regression/update-service-regression.js",
    "release:check": "node scripts/release-check.js",
    "release:checksums": "node scripts/generate-checksums.js out"
  },
  "keywords": [],
  "author": {
    "name": "funkpopo",
    "email": "funkpopoisme@gmail.com"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-transform-private-property-in-object": "7.28.6",
    "@babel/preset-react": "7.28.5",
    "@electron-forge/cli": "v8.0.0-alpha.4",
    "@electron-forge/maker-deb": "v8.0.0-alpha.4",
    "@electron-forge/maker-rpm": "v8.0.0-alpha.4",
    "@electron-forge/maker-squirrel": "v8.0.0-alpha.4",
    "@electron-forge/maker-zip": "v8.0.0-alpha.4",
    "@electron-forge/plugin-auto-unpack-natives": "v8.0.0-alpha.4",
    "@electron-forge/plugin-fuses": "v8.0.0-alpha.4",
    "@electron-forge/plugin-webpack": "v8.0.0-alpha.4",
    "@electron/fuses": "2.0.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@vercel/webpack-asset-relocator-loader": "1.10.0",
    "babel-loader": "10.1.1",
